; Sa se calculeze suma elementelor din vectorul v
.data
  v: .long 5, 10, 25
  n: .long 3

.text

.globl _start

_start:
  lea v, %edi
  // edi retine adresa de inceput a arr
  
  mov $0, %eax
  mov $0, %ecx
  
et_for_loop:
  cmp %ecx, n
  je et_exit
  
  add (%edi, %ecx, 4), %eax
  inc %ecx
  jmp et_for_loop

et_exit:
  mov $1, %eax
  mov $0, %ebx
  int $0x80

