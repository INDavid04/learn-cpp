; Suma primelor n numere
.data
	n: .long 10

.text

.globl _start

_start:
	mov $0, %eax
	mov $0, %ecx
	
et_for:
	cmp n, %ecx
	je etexit
	add %ecx, %eax
	inc %ecx
	jmp et_for

etexit:
	mov $1, %eax
	mov $0, %ebx
	int $0x80
	
; Suma primelor n numere cu loop
.data
	n: .long 10
.text
.globl _start
_start:
    mov n, %ecx
    dec %ecx
et_rep_loop:
    add %ecx, %eax
    loop et_rep_loop
etexit:
	mov $1, %eax
	mov $0, %ebx
	int $0x80

