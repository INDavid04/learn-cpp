; 3. Sa se scrie un program care calculeaza produsul numerelor congruente cu 2 (mod 3) de la 0 la n-1 
; 4. Utilizand instructiunea loop refaceti una din probleme anterioare (de exemplu, produsul elementelor de la n factorial)
.data 
    n: .long 10 
.text 
 
.global main 
 
main: 
    ; tinem suma in %eax 
    mov $0, %eax 
 
    ; initializam counterul cu 0 
    mov $0, %ecx 
    
loop_et:
    mov n, %ecx
    et:
        mul %ecx
        loop et
    
et_loop:
    cmp n, %ecx 
    je et_exit
 
    ; sunt inca in structura si pot executa instructiuni 
    add %ecx, %eax 
 
    inc %ecx 
    jmp et_loop 
 
et_exit:
    mov $1, %eax 
    mov $0, %ebx 
    int $0x80 
    
