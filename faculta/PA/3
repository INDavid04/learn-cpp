// Inductie pentru oricare n exista descompunerea
// Fie Fk cel mai mare numar Fibonacci cu Fk <= n < Fk+1
// Exista o descompunere pentru n - Fk
// Deoarece n - Fk < Fk+1 - Fk = F-1, rezulta ca termenii din n - Fk sunt mai mici decat k-1
n = int(input())
a = 1
b = 1
while b <= n:
    a,b=b,a+b
print(a, end=" ")
n -= a
while n != 0:
    a,b=b-a,a
    if a<=n:
        print(a, end=" ")
        n -= a
        
