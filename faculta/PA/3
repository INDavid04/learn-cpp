    x = int(input())
    y = int(input())
    if x > y:
        maxim, minim = x, y
    else:
        maxim, minim = y, x
else:
    x = int(input())
    minim = maxim = x
    start = 1
for i in range (start, n + 1, 1):
    x = int(input())
    y = int(input())
    if x > y:
        if x > maxim:
            maxim = x
        if y < minim:
            minim = y
    else:
        if y > maxim:
            maxim = y
        if x < minim:
            minim = x
print(f"Minimul este {minim}, maximul este {maxim}")

