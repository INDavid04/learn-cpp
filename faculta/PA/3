// 11. Sir periodic
s = input()
t = ""
for i in range(len(s) // 2 + 1, -1, -1):
    if len(s) % i != 0:
        continue
    t = s[:i] * (len(s) // i) # "ab" * 2 -> "abab"
    if t == s:
        print(f"Sirul {s} se obtine prin concatenarea lui {s[:i]} de {len(s)} // i ori")
        break
    else:
        print(f"Nu este periodic sirul {s}")

