#include <iostream>

using namespace std;

int main()
{
    int n, m, c, a = 0;
    cin >> n;
    m = n; /// m este copia lui n
    while (m != 0) {
        c = m % 10;
        a = a * 10 + c;
        m /= 10;
    }
    if (n == a) {
        cout << "palindrom";
    } else {
        cout << "nu este palindrom";
    }

    return 0;
}